# Copy to .env and edit as needed.
#
# `docker compose` reads .env at the workshop repo root automatically.

# ---------------------------------------------------------------------------
# Repo refs - branch (recommended for workshop dev) or SHA (for event-day
# reproducibility). Branch refs fast-forward on `scripts/setup.sh`, SHA refs
# detach. setup.sh git-clones into ./repos/<name>/ at these refs.
# ---------------------------------------------------------------------------
TETHYSDASH_REF=feat/agent-tool-packages
TETHYS_AGENTS_REF=main
GEOGLOWS_REF=main

# ---------------------------------------------------------------------------
# Default LLM model. The workshop pre-pulls this in setup.sh so the first
# prompt doesn't stall on a multi-GB download. The runtime default lives in
# portal_config.yml under AGENTS.MODELS[0]; this var only steers what
# setup.sh prefetches into the ollama service. Override per-CLI-call with
# `tethysdash chat --model <other>` once you're inside the container.
# ---------------------------------------------------------------------------
AGENT_MODEL=qwen3:4b
